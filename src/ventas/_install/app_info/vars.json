[
    {
        "id": "ventas",
        "caption": "Ventas",
        "help": "Variables del paquete: ventas",
        "vars": [
            {
                "varname": "ventas_fix_ref_size",
                "vardefault": "6",
                "varvalue": "6",
                "varcaption": "Tamaño de la referencia",
                "varhelp": "Cantidad de '0' alineados a la izquierda del identificador numérico para la referencia.",
                "vartype": "int",
                "varinput": {
                    "control": "number"
                }
            },
            {
                "varname": "ventas_zimpuesto",
                "vardefault": "1",
                "varvalue": "1",
                "varcaption": "Zona de impuestos",
                "varhelp": "Configuración de la zona para el cálculo de impuestos de los productos.",
                "vartype": "int",
                "varinput": {
                    "control": "select",
                    "source":{
                        "type":"list",
                        "values":[
                            {"id":"1", "const":"cInterior"},
                            {"id":"2", "const":"cFrontera"}
                        ],
                        "keyfield":"id",
                        "showfield":"const"
                    }
                }
            },
            {
                "varname": "ventas_enable_lotes",
                "vardefault": "1",
                "varvalue": "1",
                "varcaption": "Requerir lotes",
                "varhelp": "Habilitar captura de lotes en los productos",
                "vartype": "bool",
                "varinput": {
                    "control": "select",
                    "source":{
                        "type":"list",
                        "values":[
                            {"val":"1", "text":"Si"},
                            {"val":"0", "text":"No"}
                        ],
                        "showfield":"text",
                        "keyfield":"val"
                    }
                }
            },
            {
                "varname": "ventas_enable_series",
                "vardefault": "1",
                "varvalue": "1",
                "varcaption": "Requerir series",
                "varhelp": "Habilitar captura de series en los productos",
                "vartype": "bool",
                "varinput": {
                    "control": "select",
                    "source":{
                        "type":"list",
                        "values":[
                            {"val":"1", "text":"Si"},
                            {"val":"0", "text":"No"}
                        ],
                        "showfield":"text",
                        "keyfield":"val"
                    }
                }
            },
            {
                "varname": "v12.ventas.cobro",
                "vardefault": "",
                "varvalue": "VDC01",
                "varcaption": "Cobro de ventas al contado",
                "varhelp": "Categorías para ventas",
                "vartype": "string",
                "varinput": {
                    "control": "select",
                    "source":{
                        "type":"query",
                        "query":"select codigo, descripcion from categoria where tipo=1",
                        "keyfield":"codigo",
                        "showfield":"descripcion"
                    }
                }
            },
            {
                "varname": "v12.ventas.salida",
                "vardefault": "",
                "varvalue": "VDC02",
                "varcaption": "Salidas por ventas",
                "varhelp": "Categorías para ventas",
                "vartype": "string",
                "varinput": {
                    "control": "select",
                    "source":{
                        "type":"query",
                        "query":"select codigo, descripcion from categoria where tipo=3",
                        "keyfield":"codigo",
                        "showfield":"descripcion"
                    }
                }
            },
            {
                "varname": "v12.ventas.devinv",
                "vardefault": "",
                "varvalue": "VDC03",
                "varcaption": "Entrada por devolución de ventas",
                "varhelp": "Categorías para ventas",
                "vartype": "string",
                "varinput": {
                    "control": "select",
                    "source":{
                        "type":"query",
                        "query":"select codigo, descripcion from categoria where tipo=3",
                        "keyfield":"codigo",
                        "showfield":"descripcion"
                    }
                }
            },
            {
                "varname": "v12.ventas.devefec",
                "vardefault": "",
                "varvalue": "VDC04",
                "varcaption": "Egreso de efectivo por devolución de ventas",
