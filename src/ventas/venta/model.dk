#include "dkli.dkh"
#!
module ":Venta"
{
    @table_name = "venta"
    @keyfield = "sys_pk"
    @sys_fields = "sys_pk,sys_guid,sys_dtcreated,sys_timestamp,sys_info,sys_user,sys_lastuser,sys_exported,sys_dtexported,sys_recver,sys_deleted,sys_lock"

    @create_fields = "*"
    @update_fields = "*"
    
    @create_exclude_fields = "sys_lastuser,descuento1,descuento2,impuesto1,impuesto2,impuesto3,impuesto4,subtotal,serie,folio,_detalle,docs_included_id"
    @update_exclude_fields = "sys_pk,sys_guid,sys_dtcreated,sys_user,descuento1,descuento2,impuesto1,impuesto2,impuesto3,impuesto4,subtotal,serie,folio,_detalle,docs_included_id,documento,referencia,ifolio"
    
    @create_alias_fields = ""
    @update_alias_fields = ""

    @list_query = @qry_list_venta
    @read_query = @qry_read_venta
    @childs_query = @qry_dventa

    buscarCliente::&db,&params
    {
        if trim(@@(params,"$id")) != "" || trim(@@(params,"$icliente")) != ""
        {
            conditions = "(cte.sys_pk = IFNULL(@id,@icliente) OR cte.sys_guid = IFNULL(@id,@icliente))"
            return dbr.rec(db,ftext(@qry_buscar_cliente),params)
        }
        if trim(@@(params,"$search")) != ""
        {
            conditions = "NOT IFNULL(cte.sys_deleted,0)
            AND (
                cte.codigo LIKE CONCAT('%',@search,'%')
                OR cte.nombre LIKE CONCAT('%',@search,'%')
            )"
            return dbr.list(db,ftext(@qry_buscar_cliente),params)
        }
        return list.create()
    }

    buscarProducto::&db,&params
    {
        do Venta.setZonaImpuesto(db,params)
        
        conditions = "AND (p.codigo LIKE CONCAT('%',@search,'%') OR p.descripcion LIKE CONCAT('%',@search,'%'))"
        return dbr.list(db,ftext(@qry_buscar_producto),params)
    }

    buscarDocumento::&db,&params
    {
        joins = "INNER JOIN dventa AS dv ON vnt.sys_pk = dv.fk_venta_detalle"

        conditions = ftext("
        AND vnt.statusadministrativo != #<@stt_adm_cancelado>
        AND vnt.aplicadoa IS NULL
        AND vnt.icliente = @icliente
        AND (
            CASE @doctype
                WHEN #<@cPedido> THEN vnt.documento = #<@cCotizacion>
                WHEN #<@cRemision> THEN vnt.documento IN (#<@cCotizacion>,#<@cPedido>)
                WHEN #<@cFactura> THEN vnt.documento IN (#<@cCotizacion>,#<@cPedido>,#<@cRemision>)
                WHEN #<@cNotaCredito> THEN vnt.documento IN (#<@cRemision>,#<@cFactura>)
            END
        )
        AND (vnt.referencia LIKE CONCAT('%',@search,'%'))
        GROUP BY vnt.sys_pk
        HAVING SUM(IFNULL(dv.xfacturar,0)) > 0
        ")

        if @@(params,"#icliente") > 0 && @@(params,"#doctype") > 0 && trim(@@(params,"$search")) != "" { return dbr.list(db,ftext(@qry_list_venta),params) }

        return list.create()
    }

    buscarAgente::&db,&params
    {
        if trim(@@(params,"$id")) != "" || trim(@@(params,"$iagente")) != ""
        {
            conditions = "(agn.sys_pk = IFNULL(@id,@iagente) OR agn.sys_guid = IFNULL(@id,@iagente))"
            return dbr.rec(db,ftext(@qry_buscar_agente),params)
        }
        if trim(@@(params,"$search")) != ""
        {
            conditions = "NOT IFNULL(agn.sys_deleted,0)
            AND (
                agn.codigo LIKE CONCAT('%',@search,'%')
                OR agn.nombre LIKE CONCAT('%',@search,'%')
            )"
            return dbr.list(db,ftext(@qry_buscar_agente),params)
        }
        return list.create()
    }

    buscarRepartidor::&db,&params
    {
        if trim(@@(params,"$id")) != "" || trim(@@(params,"$irepartidor")) != ""
        {
            conditions = "(rep.sys_pk = IFNULL(@id,@irepartidor) OR rep.sys_guid = IFNULL(@id,@irepartidor))"
            return dbr.rec(db,ftext(@qry_buscar_repartidor),params)
        }
        if trim(@@(params,"$search")) != ""
        {
            conditions = "NOT IFNULL(rep.sys_deleted,0)
            AND (
                rep.codigo LIKE CONCAT('%',@search,'%')
                OR rep.nombre LIKE CONCAT('%',@search,'%')
            )"
            return dbr.list(db,ftext(@qry_buscar_repartidor),params)
        }
        return list.create()
    }

    buscarPorteador::&db,&params
    {
        if trim(@@(params,"$id")) != "" || trim(@@(params,"$iporteador")) != ""
        {
            conditions = "(por.sys_pk = IFNULL(@id,@iporteador) OR por.sys_guid = IFNULL(@id,@iporteador))"
            return dbr.rec(db,ftext(@qry_buscar_porteador),params)
        }
        if trim(@@(params,"$search")) != ""
        {
            conditions = "NOT IFNULL(por.sys_deleted,0)
            AND (
                por.codigo LIKE CONCAT('%',@search,'%')
                OR por.descripcion LIKE CONCAT('%',@search,'%')
            )"
            return dbr.list(db,ftext(@qry_buscar_porteador),params)
        }
        return list.create()
    }

    obtenerDocumentosIncluidos::&db,&params
    {
        ref data = record.create()

        if @@(params,"#iventa") <= 0 && @@(params,"#_entity_id") <= 0 { return data }
        docs_id = dbr.str(db,"SELECT GROUP_CONCAT(sys_pk SEPARATOR ',') FROM venta WHERE aplicadoa = IFNULL(@iventa,@_entity_id);",params)
        if docs_id == "" { return data }
        conditions = "AND vnt.sys_pk IN ("+docs_id+")"
        ref documentos = dbr.list(db,ftext(@qry_list_venta),@null)

        go foreach.lobj(value:doc) with(documentos)
        {
            data<@@(doc,"$sys_pk")+"*"> : doc
        }

        return data
    }

    obtenerDVenta::&db,&params
    {
        new p { @"_entity_id": @@(params,"#iventa") }
        do Venta.setZonaImpuesto(db,p)

        selects = ",
        vnt.referencia AS origen,
        CONCAT(ROUND(dt.cantidad - IFNULL(dt.xfacturar,dt.cantidad),0), '/' ,ROUND(dt.cantidad,0)) AS cotizado,
        vnt.sys_pk AS documento,
        dt.sys_pk AS doc_partida
        "

        joins = "INNER JOIN venta AS vnt ON dt.fk_venta_detalle = vnt.sys_pk"

        ref dventa = Venta.recoverLoteSerie(db,dbr.list(db,ftext(@qry_dventa),p))
        return dventa
    }

    obtenerLotesDeProducto::&db,&params
    {
        return dbr.list(db,@qry_lotes_de_producto,params)
    }

    obtenerSeriesDeProducto::&db,&params
    {
        return dbr.list(db,@qry_series_de_producto,params)
    }

    obtenerCliente::&db,id
    {
